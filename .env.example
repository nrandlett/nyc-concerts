# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this example file is committed so collaborators
# know which environment variables the app expects.

# Ticketmaster Discovery API key (server-only) — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe in the browser; access is gated by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — full server-side access, BYPASSES RLS. SERVER-ONLY.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret gating the /api/cron/ingest endpoint. Generate a random value
# (e.g. `openssl rand -hex 32`). Vercel Cron sends it as an
# "Authorization: Bearer <secret>" header. SERVER-ONLY.
CRON_SECRET=
