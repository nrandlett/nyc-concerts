# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this example file is committed so collaborators
# know which environment variables the app expects.

# Ticketmaster Discovery API key — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service role key — full server-side access. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon (public) key — safe to use in client code.
SUPABASE_ANON_KEY=
